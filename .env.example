# Copy this file to .env in any app folder (apps/TBC-*/), never commit .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
# EXPO_PUBLIC_ prefix makes them available in Expo client code
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── EAS / Expo ────────────────────────────────────────────────────────────────
# Not used at runtime — only needed for local EAS CLI builds
# Generate at: https://expo.dev → Account → Access Tokens
EXPO_TOKEN=your-expo-access-token
